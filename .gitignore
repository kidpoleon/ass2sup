# ── Compiled binaries ────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib

# Keep the embed directory (contains embedded Spp2Pgs PE binaries).
# The binaries themselves (.exe/.dll) are still gitignored above — only the
# directory is preserved so the package can compile when binaries are present.
!embed/
!embed/.gitkeep

# Keep the icon directory
!icon/

# ── Go toolchain ─────────────────────────────────────────────────────────────
# Test binary
*.test
# Coverage output
*.out
coverage.html
# Workspace files
go.work
go.work.sum
# Vendor directory
vendor/

# ── Windows PE resource ───────────────────────────────────────────────────────
# goversioninfo generates resource.syso; commit it so builds without the tool
# still embed the correct icon and version metadata.
*.syso
!resource.syso

# ── Build artifacts ───────────────────────────────────────────────────────────
bin/
dist/
build/

# ── Conversion output ─────────────────────────────────────────────────────────
*.sup

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.editorconfig

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Temp / logs ──────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.log
