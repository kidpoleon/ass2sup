# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.html

# Dependency directories
vendor/

# Go workspace file
go.work

# IDE directories
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
tmp/
temp/
*.tmp
*.log

# Build artifacts
bin/
dist/
build/

# Output files from conversions
*.sup

# Go resource files (generated during build)
*.syso
resource.syso

# Don't ignore the embed directory - it contains embedded binaries
!embed/
!icon/
